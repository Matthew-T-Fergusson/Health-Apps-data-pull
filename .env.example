# Athlete ingest config (copy to .env and fill values)

# General
APP_ENV=production
WORKSPACE_DIR=/absolute/path/to/workspace

# PostgreSQL
PGHOST=127.0.0.1
PGPORT=5432
PGDATABASE=health_ops
PGUSER=lex
PGPASSWORD=CHANGE_ME

# Strava OAuth
STRAVA_CLIENT_ID=CHANGE_ME
STRAVA_CLIENT_SECRET=CHANGE_ME
STRAVA_REFRESH_TOKEN=CHANGE_ME
STRAVA_TOKEN_EXPIRES_AT=

# Garmin login (community library based)
GARMIN_EMAIL=CHANGE_ME
GARMIN_PASSWORD=CHANGE_ME
GARMIN_TOKENSTORE_DIR=./output/garmin/tokenstore
GARMIN_LOCKOUT_STATE_PATH=./output/garmin/lockout_state.json
GARMIN_LOCKOUT_COOLDOWN_SECONDS=43200

# Ingest windows
GARMIN_SYNC_DAYS=7
GARMIN_ACTIVITY_LOOKBACK_DAYS=60
GARMIN_ACTIVITY_DETAIL_LOOKBACK_DAYS=90
GARMIN_READINESS_DAYS=120

# QA thresholds
HEALTH_QA_WARN_HOURS=8
HEALTH_QA_FAIL_HOURS=24

# Logging
LOG_LEVEL=INFO
